    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.20",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
